
# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/opencode_wrapper

# ── OpenCode Zen Configuration (FREE!) ──
# Get your API key from: https://opencode.ai/auth
ZEN_BASE_URL=https://opencode.ai/zen/v1
ZEN_API_KEY=

# ── Default Model ──
DEFAULT_MODEL=grok-code

# ── Server ──
PORT=3010
DEV_MODE=false
ALLOWED_ORIGINS=http://localhost:3011

# ── Rate Limiting (only when DEV_MODE=false) ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Provider API Keys (comma-separated for multiple accounts) ──
GROQ_API_KEYS=
NVIDIA_API_KEYS=
GEMINI_API_KEYS=
CEREBRAS_API_KEYS=
TOGETHER_API_KEYS=
FIREWORKS_API_KEYS=
ANTHROPIC_API_KEYS=
DEEPSEEK_API_KEYS=
MISTRAL_API_KEYS=
COHERE_API_KEYS=
OPENROUTER_API_KEYS=
AITOOLS_API_KEYS=


# ── Provider Priority ──
PROVIDER_PRIORITY=cerebras,groq,nvidia,gemini,openrouter,together,fireworks,anthropic,deepseek,mistral,cohere,opencode,aitools

# ── Performance Tuning ──
SPEED_WEIGHT_MULTIPLIER=0.4
ERROR_PENALTY_MULTIPLIER=2.0
HEALTH_CHECK_INTERVAL=30000
STATS_UPDATE_INTERVAL=5000
MAX_STATS_HISTORY=1000
PROVIDER_STATS_FILE=./provider_stats.json

# ── Ping URLs (comma-separated) ──
PING_URLS=

# ── Email ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
OWNER_MAIL=

# ── Admin Credentials ──
ADMIN_USER=
ADMIN_PASS=
